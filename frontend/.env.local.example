# 실제 API Gateway 엔드포인트 (CloudFormation Outputs > ApiEndpointUrl)
# 설정 시 Next.js Mock API 대신 실제 백엔드를 사용합니다
# 미설정 시 로컬 Mock API로 동작합니다
NEXT_PUBLIC_API_BASE_URL=https://REPLACE_WITH_API_GATEWAY_URL/prod

# ── 인증 (Google SSO / Auth.js) ──────────────────────────────────
# 아래 4개가 모두 비어 있으면 인증 없이 동작합니다 (로컬 개발용).
# 활성화하려면 Google Cloud Console에서 OAuth 2.0 클라이언트를 만들고 채우세요.
#   - 승인된 리디렉션 URI: http://localhost:3000/api/auth/callback/google
#                          https://<배포도메인>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# openssl rand -base64 32  로 생성한 임의 시크릿
AUTH_SECRET=
# 배포 시 외부 URL (로컬은 생략 가능). 예: https://alerts.example.com
# AUTH_URL=

# 허용 계정 (UX 게이트 — 실제 강제는 백엔드에서 수행).
# 백엔드 CFN 의 AllowedEmails / AllowedEmailDomains 와 동일하게 맞추세요.
ALLOWED_EMAILS=
ALLOWED_EMAIL_DOMAINS=
