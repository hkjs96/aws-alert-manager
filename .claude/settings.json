{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Kiro hooks 중 포팅 가능한 것을 Claude Code 훅으로 재구성. stderr로 리마인더를 출력하면 Claude가 이어지는 턴에서 참고한다. Kiro 측 원본은 .kiro/hooks/ 아래 그대로 유지되어 있다. permissions/defaultMode는 이 저장소에서 자율 워크플로(테스트→커밋→푸시까지 단계별 수락 없이) 실행하도록 환경 독립적 항목만 등록. 본인 PC 절대 경로 같은 환경 특화는 .claude/settings.local.json(gitignored)으로.",
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(which:*)",
      "Bash(env)",
      "Bash(date)",
      "Bash(echo:*)",
      "Bash(sed -i:*)",
      "Bash(tee /tmp/*.log)",
      "Bash(pkill -f:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(git check-ignore:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git commit -m:*)",
      "Bash(git checkout -b:*)",
      "Bash(git pull:*)",
      "Bash(git push)",
      "Bash(git push origin main)",
      "Bash(git push origin HEAD:*)",
      "Bash(git stash)",
      "Bash(git stash pop)",
      "Bash(git stash list)",
      "Bash(git merge --no-ff:*)",
      "Bash(git fetch:*)",
      "Bash(git restore:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(python -m mypy:*)",
      "Bash(python -c:*)",
      "Bash(python scripts/verify_all.py)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx eslint:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(node_modules/.bin/tsc:*)",
      "Bash(aws sts:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws s3 cp:*)",
      "Bash(aws s3 mv:*)",
      "Bash(aws s3 rm:*)",
      "Bash(aws cloudformation describe-stacks:*)",
      "Bash(aws cloudformation list-stacks:*)",
      "Bash(aws cloudformation update-stack:*)",
      "Bash(aws cloudformation describe-stack-events:*)",
      "Bash(aws lambda update-function-code:*)",
      "Bash(aws lambda get-function:*)",
      "Bash(aws lambda invoke:*)",
      "Bash(aws cloudwatch list-metrics:*)",
      "Bash(aws cloudwatch describe-alarms:*)",
      "Bash(aws cloudwatch describe-alarm-history:*)",
      "Bash(aws logs filter-log-events:*)",
      "Bash(aws logs tail:*)",
      "Bash(aws amplify list-apps:*)",
      "Bash(aws amplify list-jobs:*)",
      "Bash(aws amplify get-job:*)",
      "Bash(aws amplify update-app:*)",
      "Bash(aws amplify start-job:*)",
      "Bash(aws ec2 describe-instances:*)",
      "Bash(aws rds describe-db-instances:*)",
      "Bash(aws sns list-topics:*)",
      "Bash(aws sns publish:*)",
      "Bash(aws ssm get-parameter:*)",
      "Bash(aws ssm get-parameters:*)",
      "Bash(aws apigateway get-rest-apis:*)",
      "Bash(aws apigatewayv2 get-apis:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl https://*.amazonaws.com/*)",
      "Bash(curl https://main.*.amplifyapp.com/*)",
      "Bash(mkdir -p:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm /tmp/*)",
      "Bash(rm -rf /tmp/*)",
      "Bash(zip:*)",
      "Bash(unzip -l:*)",
      "Bash(tar -tf:*)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_FILE_PATH\" ]; then cp \"$CLAUDE_FILE_PATH\" \"$CLAUDE_FILE_PATH.bak\" 2>/dev/null; fi || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.content // .tool_input.new_string // \"\"' | grep -nE '(AKIA[0-9A-Z]{16}|(password|secret|token|api[_-]?key)\\s*=\\s*[\"'\\''][^\"'\\'' ${}]{6,})' >&2 && echo '[secret-leak-guard] ⚠️ 위 라인이 시크릿일 가능성이 있다. 환경 변수/Secrets Manager/SSM Parameter Store 사용을 검토하라. (anti-patterns.md AP-1)' >&2; exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; case \"$FILE\" in *.py) echo '[governance-check] 작성 전 확인: §1 boto3 lru_cache, §2 import 순서(stdlib→boto3→common.*), §3 복잡도(locals≤15,stmts≤50,branches≤12,args≤5), §4 ClientError만 catch·logger.error(\"%s\",e), §9 getLogger(__name__)+컨텍스트, §10 중복 금지. (.kiro/steering/coding-governance.md)' >&2 ;; esac; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; case \"$FILE\" in *.py) if command -v pylint >/dev/null 2>&1; then pylint --disable=all --enable=too-many-locals,too-many-statements,too-many-branches,too-many-arguments --max-locals=15 --max-statements=50 --max-branches=12 --max-args=5 \"$FILE\" >&2 || echo '[pylint-on-save] 복잡도 상한 초과. 헬퍼 함수로 분리하라. (§3)' >&2; fi ;; esac; exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; case \"$FILE\" in *.py) case \"$FILE\" in *test_*|*conftest*) exit 0 ;; esac; MOD=$(basename \"$FILE\" .py); TEST=\"tests/test_${MOD}.py\"; if [ -f \"$TEST\" ]; then echo \"[pytest-on-save] ${TEST} 실행 중...\" >&2; pytest \"$TEST\" -x -q --tb=short 2>&1 | head -60 >&2; fi ;; esac; exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; case \"$FILE\" in */frontend/*.ts|*/frontend/*.tsx) cd frontend && npx tsc --noEmit 2>&1 | head -40 >&2 ;; esac; exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; case \"$FILE\" in *.test.ts|*.test.tsx|*.spec.ts|*.spec.tsx) case \"$FILE\" in */frontend/*) cd frontend && npx vitest run --reporter=verbose 2>&1 | head -60 >&2 ;; esac ;; esac; exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE_PATH\"; git add \"$FILE\" 2>/dev/null || true; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/verify_all.py"
          }
        ]
      }
    ]
  },

  "_unported_kiro_hooks": {
    "_note": "아래는 Kiro에 있었으나 Claude Code에 직접 대응 훅이 없어 Slash Command 또는 수동 실행으로 남겨둔 항목.",
    "file_creation_event": "Kiro의 fileCreated 트리거는 Claude Code에 없다. new-collector-checklist는 Write 훅에서 근사 처리."
  }
}
